                  "// Verificamos que el login haya sido exitoso \r",
                  "if (pm.response.code === 200) {\r",
                  "    // Guardamos el token en una variable de Postman llamada \"jwt_token\"\r",
                  "    pm.collectionVariables.set(\"jwt_token\", respuesta.token);\r",
